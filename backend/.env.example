# Configuração do MongoDB
# Para usar MongoDB Atlas (nuvem):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/agendamento-servicos?retryWrites=true&w=majority

# Para usar MongoDB local:
# MONGODB_URI=mongodb://localhost:27017/agendamento-servicos

# Configurações do Servidor
PORT=5000
NODE_ENV=development

# Chave secreta para JWT (gerar uma chave segura)
JWT_SECRET=sua_chave_secreta_aqui_mude_isso_em_producao